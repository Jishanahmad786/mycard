<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

    <title>Md Jishan Ahmad - Profile Card</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            width:100%;
            height:100vh;

            display:flex;
            justify-content:center;
            align-items:center;

            font-family:Arial, sans-serif;

            /* Animated Background */
            background: linear-gradient(
            -45deg,
            #0f2027,
            #203a43,
            #2c5364,
            #00c9ff,
            #92fe9d);

            background-size:400% 400%;
            animation:bgMove 10s ease infinite;
        }

        /* Background Animation */
        @keyframes bgMove{
            0%{
                background-position:0% 50%;
            }
            50%{
                background-position:100% 50%;
            }
            100%{
                background-position:0% 50%;
            }
        }

        /* Main Card */
        .card{
            width:400px;
            padding:35px;

            background:cyan;
            border-radius:30px;

            text-align:center;

            box-shadow:
            0 10px 35px rgba(0,0,0,0.3);

            transition:0.4s;
        }

        .card:hover{
            transform:translateY(-8px);
        }

        /* Profile Photo */
        img{
            width:200px;
            height:200px;

            border-radius:50%;
            border:6px solid white;

            object-fit:cover;
            object-position:top;

            box-shadow:
            0 0 20px rgba(255,255,255,0.9),
            0 0 40px rgba(0,0,0,0.2);

            transition:0.5s ease;
        }

        img:hover{
            transform:scale(1.08);

            box-shadow:
            0 0 30px #ffffff,
            0 0 50px rgba(255,255,255,0.9);
        }

        /* Name */
        h1{
            margin-top:20px;

            color:#002b5b;
            font-size:35px;
            font-weight:bold;

            text-shadow:
            2px 2px 8px rgba(255,255,255,0.6);
        }

        /* Stylish Paragraph */
        .about{
            margin-top:20px;

            background: linear-gradient(
            135deg,
            #001f3f,
            #005f73);

            color:#ffffff;

            padding:22px;
            border-radius:20px;

            font-size:19px;
            font-weight:bold;
            font-style:italic;
            line-height:32px;

            border:2px solid rgba(255,255,255,0.2);

            box-shadow:
            0 8px 20px rgba(0,0,0,0.25);

            transition:0.4s;
        }

        .about:hover{
            transform:scale(1.03);
        }

        /* Buttons */
        .buttons{
            margin-top:30px;

            display:flex;
            justify-content:center;
            gap:15px;
            flex-wrap:wrap;
        }

        a{
            text-decoration:none;

            padding:14px 22px;
            border-radius:15px;

            font-size:18px;
            font-weight:bold;

            color:white;

            transition:0.4s ease;

            box-shadow:
            0 5px 15px rgba(0,0,0,0.25);
        }

        /* Call Button - Green */
        .call{
            background: linear-gradient(
            135deg,
            #11998e,
            #38ef7d);
        }

        /* WhatsApp Button - Orange Pink */
        .whatsapp{
            background: linear-gradient(
            135deg,
            #ff9966,
            #ff5e62);
        }

        /* Email Button - Purple */
        .email{
            background: linear-gradient(
            135deg,
            #7f00ff,
            #e100ff);
        }

        /* Hover Effect */
        a:hover{
            transform:
            translateY(-6px)
            scale(1.06);

            filter:brightness(1.1);

            box-shadow:
            0 10px 25px rgba(0,0,0,0.35);
        }

    </style>
</head>

<body>

    <div class="card">

        <!-- Photo -->
        <img src="jishan.jpeg"
            alt="Md Jishan Ahmad">

        <!-- Name -->
        <h1>Md Jishan Ahmad</h1>

        <!-- Paragraph -->
        <div class="about">
            I teach online classes related to
            Computer Science and help students
            learn technology.
        </div>

        <!-- Buttons -->
        <div class="buttons">

            <a class="call"
                href="tel:8340239039">
                📞 Call
            </a>

            <a class="whatsapp"
                href="https://wa.me/918340239039">
                💬 WhatsApp
            </a>

            <a class="email"
                href="mailto:mdjishanahmad442@gmail.com">
                ✉ Email
            </a>

        </div>

    </div>

</body>
</html>
